# ============================================================
#  IBM Watsonx.ai — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit the actual .env file to version control.
# ============================================================

# IBM Cloud API Key — generate from https://cloud.ibm.com/iam/apikeys
# IMPORTANT: paste your real key here — the placeholder below will not work
IBM_API_KEY=your_ibm_cloud_api_key_here

# Watsonx.ai Project ID — found in your Watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx.ai API URL — pick the region where your project lives:
#   US South  : https://us-south.ml.cloud.ibm.com
#   EU DE     : https://eu-de.ml.cloud.ibm.com
#   UK South  : https://eu-gb.ml.cloud.ibm.com
#   AP Sydney : https://au-syd.ml.cloud.ibm.com
#   JP Tokyo  : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key — use a long random string in production
FLASK_SECRET_KEY=change-me-to-a-long-random-secret-key

# Flask environment: development | production
FLASK_ENV=development

# Port to run the Flask app on
PORT=5000
